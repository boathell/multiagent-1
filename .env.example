APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_SQLITE_PATH=.data/orchestrator.db
REVIEW_MAX_LOOPS=1
REVIEW_ARBITER_MAX_LOOPS=1
MAX_CODE_FILE_LINES=1000
HUMAN_HANDOFF_ENABLED=true
TDD_ENFORCEMENT_MODE=strict

PLANE_BASE_URL=http://localhost:8080
PLANE_WORKSPACE_SLUG=test_workspace
PLANE_API_TOKEN=replace_me
PLANE_WEBHOOK_SECRET=replace_me

GITHUB_TOKEN=$GITHUB_PAT
GITHUB_USE_MOCK=false

FEISHU_WEBHOOK_URL=
FEISHU_SIGNING_SECRET=

AGENTS_USE_MOCK=false
